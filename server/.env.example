# ─── Server ───
PORT=5001

# ─── MongoDB ───
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/faqsystem?retryWrites=true&w=majority

# ─── Gemini AI ───
GEMINI_API=your_gemini_api_key_here
GEMINI_CHAT_MODEL=gemini-2.0-flash-lite
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ─── JWT ───
JWT_SECRET=generate_a_random_64_char_hex_string
JWT_EXPIRE=7d

# ─── CORS (comma-separated Vercel URLs for production) ───
# Example: CORS_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com
CORS_ORIGINS=http://localhost:5173
